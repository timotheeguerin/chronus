{
  "name": "@chronus/chronus",
  "version": "1.3.1",
  "type": "module",
  "description": "chronus",
  "homepage": "https://github.com/timotheeguerin/chronus#readme",
  "license": "MIT",
  "author": "Microsoft",
  "keywords": [
    "change",
    "changelog",
    "chronus",
    "monorepo"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./change": "./dist/change/index.js",
    "./changelog": "./dist/changelog/index.js",
    "./source-control/git": "./dist/source-control/git.js",
    "./publish": "./dist/publish/index.js",
    "./utils": "./dist/utils/index.js",
    "./reporters": "./dist/reporters/index.js",
    "./testing": "./dist/testing/index.js"
  },
  "bin": {
    "kro": "cmd/cli.mjs",
    "chronus": "cmd/cli.mjs"
  },
  "files": [
    "cmd",
    "dist"
  ],
  "repository": "timotheeguerin/chronus.git",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "watch": "tsc -p ./tsconfig.build.json --watch",
    "build": "tsc -p ./tsconfig.build.json",
    "clean": "rimraf dist/ .temp/",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest -w"
  },
  "dependencies": {
    "cross-spawn": "catalog:",
    "globby": "catalog:",
    "is-unicode-supported": "catalog:",
    "micromatch": "catalog:",
    "pacote": "catalog:",
    "picocolors": "catalog:",
    "pluralize": "catalog:",
    "prompts": "catalog:",
    "semver": "catalog:",
    "smol-toml": "catalog:",
    "source-map-support": "catalog:",
    "std-env": "catalog:",
    "yaml": "catalog:",
    "yargs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chronus/registry-mock": "workspace:*",
    "@types/cross-spawn": "catalog:",
    "@types/micromatch": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "catalog:",
    "@types/pacote": "catalog:",
    "@types/pluralize": "catalog:",
    "@types/prompts": "catalog:",
    "@types/semver": "catalog:",
    "@types/xml2js": "catalog:",
    "@types/yargs": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "bugs": "https://github.com/timotheeguerin/chronus/issues"
}
