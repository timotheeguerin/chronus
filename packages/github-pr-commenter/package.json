{
  "name": "@chronus/github-pr-commenter",
  "version": "1.1.0",
  "description": "chronus",
  "keywords": [
    "change",
    "changelog",
    "chronus",
    "github",
    "monorepo"
  ],
  "homepage": "https://github.com/timotheeguerin/chronus#readme",
  "bugs": "https://github.com/timotheeguerin/chronus/issues",
  "license": "MIT",
  "author": "Microsoft",
  "repository": "timotheeguerin/chronus.git",
  "bin": {
    "chronus-github-pr-commenter": "./cmd/cli.mjs"
  },
  "files": [
    "cmd",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "watch": "tsc -p ./tsconfig.build.json --watch",
    "build": "tsc -p ./tsconfig.build.json",
    "build-vite": "vite build",
    "clean": "rimraf dist/ .temp/",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest -w"
  },
  "dependencies": {
    "@chronus/github": "workspace:*",
    "@octokit/rest": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
