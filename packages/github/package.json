{
  "name": "@chronus/github",
  "version": "1.0.6",
  "description": "chronus",
  "keywords": [
    "change",
    "changelog",
    "chronus",
    "github",
    "monorepo"
  ],
  "homepage": "https://github.com/timotheeguerin/chronus#readme",
  "bugs": "https://github.com/timotheeguerin/chronus/issues",
  "license": "MIT",
  "author": "Microsoft",
  "repository": "timotheeguerin/chronus.git",
  "bin": {
    "chronus-github": "./cmd/cli.mjs"
  },
  "files": [
    "cmd",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./pull-requests": "./dist/pull-requests/index.js",
    "./changelog": "./dist/changelog/index.js"
  },
  "scripts": {
    "watch": "tsc -p ./tsconfig.build.json --watch",
    "build": "tsc -p ./tsconfig.build.json",
    "clean": "rimraf dist/ .temp/",
    "lint": "oxlint -c ../../.oxlintrc.ts --max-warnings=0",
    "lint:fix": "oxlint -c ../../.oxlintrc.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest -w"
  },
  "dependencies": {
    "@chronus/chronus": "workspace:*",
    "@octokit/graphql": "catalog:",
    "@octokit/rest": "catalog:",
    "cross-spawn": "catalog:",
    "octokit": "catalog:",
    "picocolors": "catalog:",
    "yargs": "catalog:"
  },
  "devDependencies": {
    "@types/cross-spawn": "catalog:",
    "@types/node": "catalog:",
    "@types/yargs": "catalog:",
    "rimraf": "catalog:",
    "source-map-support": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
